{
  "name": "sessionsmith",
  "displayName": "SessionSmith",
  "description": "Git-style session management for Python with a visual gitgraph-like session graph. Save, restore, branch, tag and inspect your Python variables in Jupyter Notebooks and Python files.",
  "version": "0.2.0",
  "publisher": "yut0takagi",
  "author": {
    "name": "yut0takagi"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yut0takagi/SessionSmith.git"
  },
  "homepage": "https://github.com/yut0takagi/SessionSmith",
  "bugs": {
    "url": "https://github.com/yut0takagi/SessionSmith/issues"
  },
  "keywords": [
    "python",
    "session",
    "save",
    "load",
    "jupyter",
    "notebook",
    "variables",
    "pickle",
    "serialization",
    "gitgraph",
    "version-control",
    "checkpoint"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Data Science",
    "Machine Learning",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onView:sessionsmithSessions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sessionsmith.showSessionGraph",
        "title": "Open Session Graph",
        "category": "SessionSmith",
        "icon": "$(git-commit)"
      },
      {
        "command": "sessionsmith.refreshTree",
        "title": "Refresh Sessions",
        "category": "SessionSmith",
        "icon": "$(refresh)"
      },
      {
        "command": "sessionsmith.saveSession",
        "title": "Save Session",
        "category": "SessionSmith"
      },
      {
        "command": "sessionsmith.loadSession",
        "title": "Load Session",
        "category": "SessionSmith"
      },
      {
        "command": "sessionsmith.showSessionInfo",
        "title": "Show Session Info",
        "category": "SessionSmith"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sessionsmith",
          "title": "SessionSmith",
          "icon": "$(git-commit)"
        }
      ]
    },
    "views": {
      "sessionsmith": [
        {
          "id": "sessionsmithSessions",
          "name": "Sessions",
          "icon": "$(git-commit)",
          "contextualTitle": "SessionSmith"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sessionsmith.showSessionGraph",
          "when": "view == sessionsmithSessions",
          "group": "navigation@1"
        },
        {
          "command": "sessionsmith.refreshTree",
          "when": "view == sessionsmithSessions",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "sessionsmith.refreshTree",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "sessionsmith.showSessionInfo",
          "when": "resourceExtname == '.pkl' || resourceExtname == '.json' || resourceExtname == '.msgpack' || resourceExtname == '.h5'",
          "group": "sessionsmith"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
